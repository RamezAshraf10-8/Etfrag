import React, { useEffect, useState } from "react";
import { Routes, Route, Navigate } from "react-router-dom";
import { onAuthStateChanged } from "firebase/auth";
import { ToastContainer } from "react-toastify";
import { auth } from "./firebase";

import Home from "./pages/Home/Home";
import Login from "./pages/Login/Login";
import Player from "./pages/Player/Player";
import Reset from "./pages/Reset/Reset";
import MovieDetails from "./pages/MovieDetails/MovieDetails";

import HelpCentre from "./pages/HelpCentre/HelpCentre";
import Terms from "./pages/Terms/Terms";
import ContactUs from "./pages/ContactUs/ContactUs";
import Languages from "./pages/Languages/Languages";
import MyList from "./pages/MyList/MyList";

// Multi-profile pages
import Profiles from "./pages/Profiles/Profiles";
import CreateProfile from "./pages/CreateProfile/CreateProfile";

const App = () => {
const [user, setUser] = useState(null);
const [activeProfile, setActiveProfile] = useState(null);
const [loading, setLoading] = useState(true);
const [searchQuery, setSearchQuery] = useState("");
const [allMovies, setAllMovies] = useState([]);

const API_KEY = "661840277a0faebc10ce706ad40ddd47";
const categories = ["top_rated", "popular", "upcoming", "now_playing"];

// Fetch all movies once
useEffect(() => {
const fetchAll = async () => {
try {
let results = [];
for (const category of categories) {
for (let page = 1; page <= 3; page++) {
const res = await fetch(
`https://api.themoviedb.org/3/movie/${category}?api_key=${API_KEY}&language=en-US&page=${page}`
);
const data = await res.json();
if (data.results) results.push(...data.results);
}
}
const uniqueMovies = Array.from(new Map(results.map(m => [m.id, m])).values());
setAllMovies(uniqueMovies);
} catch (err) {
console.error(err);
}
};
fetchAll();
}, []);

// Monitor Firebase auth
useEffect(() => {
const unsub = onAuthStateChanged(auth, (currentUser) => {
setUser(currentUser);
setLoading(false);
});
return () => unsub();
}, []);

// Load active profile
useEffect(() => {
const saved = localStorage.getItem("activeProfile");
if (saved) setActiveProfile(JSON.parse(saved));
}, []);

if (loading) {
return (
<div
style={{
height: "100vh",
color: "white",
display: "flex",
alignItems: "center",
justifyContent: "center",
background: "black",
fontSize: "22px",
}}
>
Loading... </div>
);
}

// Route protection
const requireUser = (element) =>
user ? element : <Navigate to="/login" replace />;

const requireProfile = (element) =>
!user
? <Navigate to="/login" replace />
: !activeProfile
? <Navigate to="/profiles" replace />
: element;

return ( <div> <ToastContainer theme="dark" />


  <Routes>
    {/* LOGIN FLOW */}
    <Route
      path="/login"
      element={!user ? <Login /> : <Navigate to="/profiles" replace />}
    />
    <Route path="/reset" element={<Reset />} />

    {/* PROFILE PAGES */}
    <Route
      path="/profiles"
      element={requireUser(<Profiles />)}
    />
    <Route
      path="/create-profile"
      element={requireUser(<CreateProfile />)}
    />

    {/* MAIN APP PAGES (require user + profile) */}
    <Route
      path="/"
      element={requireProfile(
        <Home searchQuery={searchQuery} setSearchQuery={setSearchQuery} />
      )}
    />

    <Route
      path="/player/:id"
      element={requireProfile(<Player />)}
    />

    <Route
      path="/movie/:id"
      element={requireProfile(<MovieDetails />)}
    />

    <Route
      path="/languages"
      element={requireProfile(
        <Languages
          searchQuery={searchQuery}
          setSearchQuery={setSearchQuery}
          allMovies={allMovies}
        />
      )}
    />

    <Route
      path="/mylist"
      element={requireProfile(
        <MyList
          searchQuery={searchQuery}
          setSearchQuery={setSearchQuery}
          allMovies={allMovies}
        />
      )}
    />

    {/* FOOTER PAGES (no login needed) */}
    <Route path="/help" element={<HelpCentre />} />
    <Route path="/terms" element={<Terms />} />
    <Route path="/contact" element={<ContactUs />} />        
  </Routes>
</div>


);
};

export default App;
